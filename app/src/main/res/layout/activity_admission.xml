<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/tvAdmissionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Admission"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvAdmissionInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Welcome to Kathmandu Shiksha Campus Admission Page.\n\nYou can find information about eligibility, admission procedures, and important dates here."
        android:textSize="16sp"
        android:textColor="#333333"/>

    <Button
        android:id="@+id/btnApplyNow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Apply Now"
        android:layout_marginTop="24dp"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"/>

</LinearLayout>